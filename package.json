{
  "name": "@imcsorin/react-native-ota",
  "version": "0.1.7",
  "description": "OTA updates for React Native",
  "main": "./lib/module/library/index.js",
  "types": "./lib/typescript/src/library/index.d.ts",
  "bin": {
    "react-native-ota-release": "./bin/react-native-ota-release"
  },
  "exports": {
    ".": {
      "source": "./src/library/index.tsx",
      "types": "./lib/typescript/src/library/index.d.ts",
      "default": "./lib/module/library/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "bin",
    "scripts",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "react-native.config.js",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "example": "yarn workspace @imcsorin/react-native-ota-example",
    "ota:serve": "node ./server/ota-server.mjs",
    "clean": "del-cli android/build examples/0.85/android/build examples/0.85/android/app/build examples/0.85/ios/build lib",
    "ota:publish": "node ./bin/react-native-ota-release.mjs publish",
    "prepare": "bob build",
    "typecheck": "tsc",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "lint:fix": "eslint \"**/*.{js,ts,tsx}\" --fix",
    "format": "prettier --write \"**/*.{js,ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,ts,tsx,json,md}\"",
    "ota:test": "node ./e2e/run.mjs",
    "test": "jest",
    "release": "release-it --only-version"
  },
  "keywords": [
    "react-native",
    "ios",
    "android"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/imcsorin/react-native-ota.git"
  },
  "author": "Sorin <work@csorin.com> (https://github.com/imcsorin)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/imcsorin/react-native-ota/issues"
  },
  "homepage": "https://github.com/imcsorin/react-native-ota#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.907.0",
    "archiver": "^7.0.1"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/compat": "^2.0.3",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@jest/globals": "29.7.0",
    "@react-native/babel-preset": "0.85.0",
    "@react-native/eslint-config": "0.85.0",
    "@react-native/jest-preset": "0.85.0",
    "@release-it/conventional-changelog": "^10.0.6",
    "@types/react": "^19.2.0",
    "commitlint": "^20.5.0",
    "del-cli": "^7.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-ft-flow": "^3.0.11",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "29.7.0",
    "lefthook": "^2.1.4",
    "prettier": "^3.8.1",
    "react": "19.2.3",
    "react-native": "0.85.0",
    "react-native-builder-bob": "^0.41.0",
    "release-it": "^19.2.4",
    "turbo": "^2.8.21",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "workspaces": [
    "examples/*"
  ],
  "packageManager": "yarn@4.11.0",
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "codegenConfig": {
    "name": "ReactNativeOtaSpec",
    "type": "modules",
    "jsSrcsDir": "src/library",
    "android": {
      "javaPackageName": "com.imcsorin.reactnativeota"
    }
  },
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  },
  "jest": {
    "preset": "@react-native/jest-preset",
    "modulePathIgnorePatterns": [
      "<rootDir>/examples/",
      "<rootDir>/lib/"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "release-it": {
    "git": {
      "commitArgs": [
        "-a"
      ]
    },
    "npm": {
      "publish": true,
      "skipChecks": true
    },
    "github": {
      "release": true
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": {
          "name": "angular"
        }
      }
    }
  },
  "create-react-native-library": {
    "type": "turbo-module",
    "languages": "kotlin-objc",
    "tools": [
      "eslint",
      "jest",
      "lefthook",
      "release-it"
    ],
    "version": "0.62.0"
  }
}
